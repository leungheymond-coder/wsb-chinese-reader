# Anthropic API
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Email (SMTP) — Gmail example; use an App Password if 2FA is on
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your-gmail-app-password

# Where to send new article notifications
NOTIFY_EMAIL=your@email.com

# Server
PORT=3000

# Timezone (for scheduler)
TZ=Asia/Hong_Kong

# Optional: Seeking Alpha credentials for full article access
SA_EMAIL=
SA_PASSWORD=
