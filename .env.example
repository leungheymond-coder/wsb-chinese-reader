# Anthropic Claude API (translation)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Google Gemini API (article fetch fallback)
GEMINI_API_KEY=your-gemini-api-key

# Tavily API (article content fetching)
TAVILY_API_KEY=tvly-your-key-here

# Email — Resend API (Gmail SMTP is blocked on Railway)
RESEND_API_KEY=re_your-key-here
NOTIFY_EMAIL=your@email.com

# Web app URL (used for deep links in notification emails)
# Local: http://localhost:3000  |  Production: https://your-app.up.railway.app
APP_URL=http://localhost:3000

# Seeking Alpha credentials (for Playwright — currently blocked by PerimeterX)
SA_EMAIL=your@email.com
SA_PASSWORD=your-password

# Server
PORT=3000
TZ=America/Toronto
